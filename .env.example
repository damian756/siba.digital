# SIBA Digital — Environment Variables
# Copy this file to .env.local and fill in values

# Contact form email (Resend API Key — https://resend.com)
RESEND_API_KEY=

# Address to receive audit enquiry emails
CONTACT_EMAIL=

# Cloudflare origin verification — set in Cloudflare Transform Rules as x-cf-access-secret header
# Generate with: openssl rand -hex 32
CF_ACCESS_SECRET=
